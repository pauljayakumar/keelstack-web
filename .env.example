# ============================================================
# KEELSTACK — environment variables
# Copy to .env.local and fill in. Nothing here is real yet.
# ============================================================

# Anthropic — used by /api/seo-report and /api/website-build to
# generate the free SEO audit + the free website preview.
ANTHROPIC_API_KEY=

# Resend (or any transactional email provider) — used to deliver
# the free artifact + the Stripe payment link to the prospect.
RESEND_API_KEY=
FROM_EMAIL=hello@keelstack.example

# Stripe — payment links (one per service tier). The follow-up
# email appends these. You can hard-code static payment links
# instead of using the API.
STRIPE_PAYMENT_LINK_SEO=
STRIPE_PAYMENT_LINK_WEBSITE=

# Where free website previews get deployed (e.g. a Vercel project
# or an S3 bucket). The /api/website-build endpoint returns this
# URL to the prospect.
PREVIEW_BASE_URL=https://preview.keelstack.example
